# Supabase (required for auth + database)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-default-key

# Vercel Blob (required for video uploads)
# Created when you add Blob storage to your Vercel project
# Or set locally: https://vercel.com/docs/storage/vercel-blob/using-blob-sdk#create-a-blob-store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

APP_ORIGIN_ALLOWLIST=http://localhost:3000,https://your-domain.com,*.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-domain.com
VIEW_TOKEN_SECRET=

# Upstash Redis (for view API rate limiting). Optional: if unset, rate limiting is skipped (e.g. local dev).
# Create a Redis database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=